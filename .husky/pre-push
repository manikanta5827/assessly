# Check if current branch is main
branch="$(git rev-parse --abbrev-ref HEAD)"
if [ "$branch" = "main" ]; then
  echo "❌ Direct pushes to 'main' branch are prohibited. Please use a feature branch and create a Pull Request."
  exit 1
fi

# Get list of changed files compared to main
# If on main, just check the commits being pushed
if [ "$branch" = "main" ]; then
  CHANGED_FILES=$(git diff --name-only HEAD@{1} HEAD)
else
  # Check if origin/main exists, otherwise use main
  if git rev-parse --verify origin/main >/dev/null 2>&1; then
    BASE_BRANCH="origin/main"
  else
    BASE_BRANCH="main"
  fi
  CHANGED_FILES=$(git diff --name-only $BASE_BRANCH...HEAD)
fi

# Conditional Backend Build
if echo "$CHANGED_FILES" | grep -q "^backend/"; then
  echo "📦 Backend changes detected, running sam build..."
  npm run build:backend
fi

# Conditional Frontend Build
if echo "$CHANGED_FILES" | grep -E "^frontend/src/.*\.([tj]sx?)$" | grep -q .; then
  echo "⚛️ Frontend source changes detected, running npm run build..."
  npm run build:frontend
fi
