{
  "name": "assessly",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "prepare": "husky",
    "lint:backend": "npm run lint --prefix backend",
    "typecheck:backend": "npm run typecheck --prefix backend",
    "validate:backend": "sam validate --lint -t backend/template.yaml",
    "build:backend": "cd backend && sam build --cached --parallel",
    "build:frontend": "npm run build --prefix frontend",
    "lint:frontend": "npm run lint --prefix frontend",
    "typecheck:frontend": "npm run typecheck --prefix frontend"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0"
  },
  "lint-staged": {
    "backend/src/**/*.{ts,js}": [
      "npm run lint:fix --prefix backend",
      "npm run typecheck --prefix backend"
    ],
    "backend/template.yaml": [
      "npm run validate:backend"
    ],
    "frontend/src/**/*.{ts,tsx,js,jsx}": [
      "npm run lint --prefix frontend",
      "npm run typecheck --prefix frontend"
    ]
  }
}
