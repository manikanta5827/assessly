generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-arm64-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
}

enum AssessmentStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

model Assessment {
  id     String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId String? @map("user_id")
  ipHash String  @map("ip_hash")

  repoUrl          String  @map("repo_url")
  requirementsText String  @map("requirements_text")
  repoSnapshot     String? @map("repo_snapshot") // The big markdown DFS output

  status AssessmentStatus @default(PENDING)

  score              Int?
  
  summary            String? @map("summary")
  requirements       Json?   @map("requirements")
  requirementsEvaluation Json? @map("requirements_evaluation")
  
  codeQuality        Json?   @map("code_quality")
  runnability        Json?   @map("runnability")
  commitAnalysis     Json?   @map("commit_analysis")
  aiAnalysis         Json?   @map("ai_analysis")
  
  requirementScore   Float?  @map("requirement_score")
  codeQualityScore   Float?  @map("code_quality_score")
  runnabilityScore   Float?  @map("runnability_score")
  aiAnalysisScore    Float?  @map("ai_analysis_score")
  
  finalReport        Json?   @map("final_report")

  interviewQuestions Json? @map("interview_questions")
  testDetection      Json? @map("test_detection")
  repoMap            Json? @map("repo_map")

  aiUsageDetection   Json? @map("ai_usage_detection") // Legacy
  
  testExecuted Boolean @default(false) @map("test_executed")
  testResults  Json?   @map("test_results")
  
  // Usage tracking
  inputTokens   Int?     @map("input_tokens")
  outputTokens  Int?     @map("output_tokens")
  totalTokens   Int?     @map("total_tokens")
  estimatedCost Decimal? @map("estimated_cost") @db.Decimal(10, 6)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")

  @@map("assessments")
}

model IpTracking {
  ipHash          String   @id @map("ip_hash")
  assessmentCount Int      @default(0) @map("assessment_count")
  firstSeenAt     DateTime @default(now()) @map("first_seen_at")
  lastSeenAt      DateTime @default(now()) @map("last_seen_at")

  @@map("ip_tracking")
}
