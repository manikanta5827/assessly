generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-arm64-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
}

enum AssessmentStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

model Assessment {
  id     String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId String? @map("user_id")
  ipHash String  @map("ip_hash")

  repoUrl          String  @map("repo_url")
  requirementsText String  @map("requirements_text")
  repoSnapshot     String? @map("repo_snapshot") // The big markdown DFS output

  status AssessmentStatus @default(PENDING)

  score Int?

  summary String? @map("summary")

  requirementScore Float? @map("requirement_score")
  codeQualityScore Float? @map("code_quality_score")
  runnabilityScore Float? @map("runnability_score")
  aiAnalysisScore  Float? @map("ai_analysis_score")

  requirements       ProjectRequirements[]
  codeQuality        CodeQuality?
  runnability        Runnability?
  aiAnalysis         AiAnalysis?
  commitAnalysis     CommitAnalysis?
  finalReport        FinalReport?
  interviewQuestions InterviewQuestion[]
  repoMap            Json?                 @map("repo_map")

  testExecuted Boolean @default(false) @map("test_executed")
  testResults  Json?   @map("test_results")

  // Usage tracking
  inputTokens   Int?     @map("input_tokens")
  outputTokens  Int?     @map("output_tokens")
  totalTokens   Int?     @map("total_tokens")
  estimatedCost Decimal? @map("estimated_cost") @db.Decimal(10, 6)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")

  @@map("assessments")
}

model IpTracking {
  ipHash          String   @id @map("ip_hash")
  assessmentCount Int      @default(0) @map("assessment_count")
  firstSeenAt     DateTime @default(now()) @map("first_seen_at")
  lastSeenAt      DateTime @default(now()) @map("last_seen_at")

  @@map("ip_tracking")
}

enum RequirementStatus {
  MET
  PARTIAL
  NOT_MET
  PENDING
}

model ProjectRequirements {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  assessmentId   String   @db.Uuid
  requirementId  String   @map("requirement_id")
  text           String
  category       String?
  suggestedFiles String[] @map("suggested_files")

  status          RequirementStatus @default(PENDING)
  confidence      Float?
  evidenceFile    String?           @map("evidence_file")
  evidenceSnippet String?           @map("evidence_snippet")
  reasoning       String?

  assessment Assessment @relation(fields: [assessmentId], references: [id], onDelete: Cascade)

  @@map("project_requirements")
}

model CodeQuality {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  assessmentId  String   @unique @db.Uuid
  score         Float
  readability   Float
  structure     Float
  naming        Float
  bestPractices Float    @map("best_practices")
  summary       String
  issues        String[]

  assessment Assessment @relation(fields: [assessmentId], references: [id], onDelete: Cascade)

  @@map("code_quality")
}

model Runnability {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  assessmentId  String   @unique @db.Uuid
  score         Float
  hasDocker     Boolean  @map("has_docker")
  hasEnvExample Boolean  @map("has_env_example")
  hasScripts    Boolean  @map("has_scripts")
  ciDetected    Boolean  @map("ci_detected")
  summary       String
  issues        String[]

  hasTests      Boolean? @map("has_tests")
  testLanguage  String?  @map("test_language")
  testFramework String?  @map("test_framework")
  testCommand   String?  @map("test_command")
  testPath      String?  @map("test_path")
  testReason    String?  @map("test_reason")

  assessment Assessment @relation(fields: [assessmentId], references: [id], onDelete: Cascade)

  @@map("runnability")
}

model AiAnalysis {
  id                   String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  assessmentId         String  @unique @db.Uuid
  score                Float
  confidence           Float
  uniformStyle         Boolean @map("uniform_style")
  lowIterationEvidence Boolean @map("low_iteration_evidence")
  genericPatterns      Boolean @map("generic_patterns")
  summary              String
  reasoning            String

  assessment Assessment @relation(fields: [assessmentId], references: [id], onDelete: Cascade)

  @@map("ai_analysis")
}

model CommitAnalysis {
  id           String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  assessmentId String @unique @db.Uuid
  qualityScore Float  @map("quality_score")
  pattern      String
  summary      String
  reasoning    String

  assessment Assessment @relation(fields: [assessmentId], references: [id], onDelete: Cascade)

  @@map("commit_analysis")
}

model FinalReport {
  id                   String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  assessmentId         String   @unique @db.Uuid
  score                Float
  summary              String
  strengths            String[]
  weaknesses           String[]
  hiringRecommendation String   @map("hiring_recommendation")

  assessment Assessment @relation(fields: [assessmentId], references: [id], onDelete: Cascade)

  @@map("final_report")
}

model InterviewQuestion {
  id           String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  assessmentId String @db.Uuid
  question     String
  focusArea    String @map("focus_area")

  assessment Assessment @relation(fields: [assessmentId], references: [id], onDelete: Cascade)

  @@map("interview_questions")
}
