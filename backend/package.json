{
  "name": "assessly-backend",
  "version": "1.0.0",
  "description": "Assessly Backend - AWS SAM",
  "main": "index.js",
  "scripts": {
    "build": "sam validate --lint && sam build --parallel",
    "deploy": "sam deploy --config-env dev --no-confirm-changeset",
    "lambda": "sam local start-api --warm-containers EAGER --env-vars env.json",
    "delete": "aws cloudformation delete-stack --stack-name Assessly-Prod",
    "lambda:sync": "sam sync --watch --stack-name Assessly-Dev",
    "fetch-env": "bash scripts/fetch-env.sh",
    "db:generate": "npx drizzle-kit generate",
    "db:migrate": "npx drizzle-kit migrate",
    "db:push": "npx drizzle-kit push",
    "db:studio": "npx drizzle-kit studio",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src",
    "format": "prettier --write \"src/**/*.ts\"",
    "lint:fix": "eslint src --fix "
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1030.0",
    "@aws-sdk/client-sqs": "^3.0.0",
    "drizzle-orm": "^0.45.2",
    "esbuild": "^0.25.12",
    "openai": "^4.85.4",
    "postgres": "^3.4.9",
    "unzipper": "^0.12.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/aws-lambda": "^8.10.0",
    "@types/node": "^24.0.0",
    "@types/unzipper": "^0.10.11",
    "drizzle-kit": "^0.31.10",
    "eslint": "^10.2.0",
    "globals": "^17.5.0",
    "prettier": "^3.8.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.58.1"
  }
}
