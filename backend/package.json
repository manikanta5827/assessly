{
  "name": "assessly-backend",
  "version": "1.0.0",
  "description": "Assessly Backend - AWS SAM",
  "main": "index.js",
  "scripts": {
    "build": "prisma generate && sam validate --lint && sam build --parallel",
    "deploy": "sam deploy --config-env dev --no-confirm-changeset",
    "lambda": "sam local start-api --warm-containers EAGER --env-vars env.json",
    "delete": "aws cloudformation delete-stack --stack-name assessly-backend",
    "lambda:sync": "sam sync --watch --stack-name Assessly-Dev",
    "fetch-env": "bash scripts/fetch-env.sh",
    "postinstall": "prisma generate",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:migrate:deploy": "prisma migrate deploy",
    "prisma:reset": "prisma migrate reset",
    "prisma:format": "prisma format",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src",
    "format": "prettier --write \"src/**/*.ts\"",
    "lint:fix": "eslint src --fix "
  },
  "dependencies": {
    "@aws-sdk/client-sqs": "^3.0.0",
    "@langchain/anthropic": "^0.3.0",
    "@langchain/openai": "^0.3.0",
    "@prisma/adapter-pg": "^7.7.0",
    "@prisma/client": "^7.7.0",
    "@supabase/supabase-js": "^2.0.0",
    "esbuild": "^0.25.12",
    "langchain": "^0.3.0",
    "pg": "^8.13.3",
    "unzipper": "^0.12.3",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/aws-lambda": "^8.10.0",
    "@types/node": "^24.0.0",
    "@types/pg": "^8.11.11",
    "@types/unzipper": "^0.10.11",
    "eslint": "^10.2.0",
    "globals": "^17.5.0",
    "prettier": "^3.8.2",
    "prisma": "^7.7.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.58.1"
  }
}
